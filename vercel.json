{
  "version": 2,
  "builds": [
    {
      "src": "backend/server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/server/index.js"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/frontend/client/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/client/index.html"
    }
  ]
}
